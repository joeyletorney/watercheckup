# Copy to .env.local and fill in. Never commit .env.local.

NEXT_PUBLIC_GA_ID=

# Resend — https://resend.com/api-keys
RESEND_API_KEY=re_your_key_here

# Optional: pin audience UUID from Resend → Audiences (otherwise created/found as "WaterCheckup")
RESEND_AUDIENCE_ID=

# From address: domain must be verified in Resend → Domains (e.g. reports@yourdomain.com)
RESEND_FROM_EMAIL=WaterCheckup <hello@yourdomain.com>

# Production: set in Vercel; Vercel Cron sends Authorization: Bearer <CRON_SECRET> automatically
# CRON_SECRET=

# Brevo (marketing CRM) — https://app.brevo.com/settings/keys/api
# Optional; if unset, Resend-only flow is unchanged.
BREVO_API_KEY=
# Comma-separated list IDs (Contacts → Lists → ID in URL or list settings), e.g. 3,5
BREVO_LIST_IDS=

# Shown on water reports when you refresh lib/ucmr5.json without redeploying copy (e.g. "June 2025")
# WATERCHECKUP_UCMR_SNAPSHOT_LABEL=
